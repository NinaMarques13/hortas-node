# =====================================================
# ⚙️ Variáveis de Ambiente — Hortas Marketplace API
# Copie este arquivo para .env e preencha os valores
# =====================================================

# Servidor
PORT=3000

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=hortas_db

# JWT — troque por uma string longa e aleatória em produção
JWT_SECRET_KEY=troque_por_uma_chave_secreta_segura_aqui

# CORS — origens permitidas (separadas por vírgula)
# Use * para permitir todas (não recomendado em produção)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
